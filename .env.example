# Runtime
F1_ENV=local
F1_LOG_LEVEL=INFO
F1_API_HOST=0.0.0.0
F1_API_PORT=8000
F1_BUILD_SHA=local
F1_BUILD_DATE=local
F1_MODEL_BACKEND=auto
F1_MODEL_ARTIFACT_ID=
F1_MODEL_ARTIFACT_ROOT=artifacts/models
F1_XGBOOST_MODEL_PATH=models/xgboost_lap_delta.json
F1_LIGHTGBM_MODEL_PATH=models/lightgbm_lap_delta.txt
F1_CATBOOST_MODEL_PATH=models/catboost_lap_delta.cbm
F1_SEQUENCE_MODEL_PATH=models/sequence_lap_delta.pt

# Inference and feature state
F1_FEATURE_WINDOW_SIZE=50
F1_TARGET_LATENCY_MS=25
F1_BASE_LAP_TIME_S=90
F1_PIT_LOSS_S=21

# Drift and regression gates
F1_DRIFT_THRESHOLD_Z=3
F1_MAX_TEMPORAL_OSCILLATION_S=1.25
F1_MAX_CALIBRATION_WIDTH_S=1.80

# Optional external systems for production deployment
F1_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
F1_REDIS_URL=redis://localhost:6379/0
F1_CLICKHOUSE_DSN=http://localhost:8123/default
F1_MLFLOW_TRACKING_URI=http://localhost:5000
F1_MLFLOW_UI_URL=http://localhost:5000
F1_GRAFANA_URL=http://localhost:3000
F1_PROMETHEUS_URL=http://localhost:9090
F1_PROMETHEUS_ENABLED=true

# Optional durable local persistence
F1_PERSISTENCE_BACKEND=auto
F1_DUCKDB_PATH=data/f1_strategy.duckdb

# Optional FastF1 replay export defaults
FASTF1_YEAR=2024
FASTF1_EVENT=Bahrain
FASTF1_SESSION=R
FASTF1_DRIVER=VER
FASTF1_OUTPUT=data/fastf1_replay.csv
FASTF1_CACHE=data/fastf1-cache
