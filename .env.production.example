# Production environment template.
# Copy to .env.production and fill in real values before deploying.
# NEVER commit .env.production — it is in .gitignore.

# ── API runtime ───────────────────────────────────────────────────────────────
F1_ENV=production
F1_LOG_LEVEL=INFO
F1_API_HOST=0.0.0.0
F1_API_PORT=8000
F1_BUILD_SHA=unknown        # set by deploy.sh / CI
F1_BUILD_DATE=unknown       # set by deploy.sh / CI

# ── Model serving ─────────────────────────────────────────────────────────────
# Set to xgboost once you have trained and promoted an artifact.
F1_MODEL_BACKEND=auto
F1_MODEL_ARTIFACT_ID=
F1_MODEL_ARTIFACT_ROOT=/artifacts/models
F1_XGBOOST_MODEL_PATH=models/xgboost_lap_delta.json
F1_LIGHTGBM_MODEL_PATH=models/lightgbm_lap_delta.txt
F1_CATBOOST_MODEL_PATH=models/catboost_lap_delta.cbm
F1_SEQUENCE_MODEL_PATH=models/sequence_lap_delta.pt

# ── Inference tuning ──────────────────────────────────────────────────────────
F1_FEATURE_WINDOW_SIZE=50
F1_TARGET_LATENCY_MS=25
F1_BASE_LAP_TIME_S=90
F1_PIT_LOSS_S=21
F1_DRIFT_THRESHOLD_Z=3
F1_MAX_TEMPORAL_OSCILLATION_S=1.25
F1_MAX_CALIBRATION_WIDTH_S=1.80

# ── Persistence ───────────────────────────────────────────────────────────────
F1_PERSISTENCE_BACKEND=duckdb
F1_DUCKDB_PATH=/data/f1_strategy.duckdb

# ── Feature store ─────────────────────────────────────────────────────────────
F1_FEATURE_STORE_BACKEND=auto
F1_REDIS_URL=redis://redis:6379/0

# ── MLflow ────────────────────────────────────────────────────────────────────
F1_MLFLOW_TRACKING_URI=http://mlflow:5000
F1_MLFLOW_UI_URL=http://mlflow:5000

# ── External links shown in the UI ───────────────────────────────────────────
# These are the public-facing URLs served through nginx.
F1_GRAFANA_URL=https://167.233.125.215/grafana
F1_PROMETHEUS_URL=http://167.233.125.215:9090

# ── Grafana admin credentials (used by docker-compose.prod.yml) ───────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME      # ← must be changed before first deploy
GF_ROOT_URL=https://167.233.125.215/grafana
